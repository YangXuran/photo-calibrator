{
  "name": "photo-calibrator-workbench",
  "version": "0.1.0",
  "description": "Cross-platform photo color analysis and calibration desktop app",
  "author": "Yang Xuran",
  "repository": "https://github.com/YangXuran/photo-calibrator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop-mock": "VITE_RUNTIME_MODE=desktop-shell VITE_SHELL_NAME='Photo Calibrator Desktop' VITE_API_BASE_URL=http://127.0.0.1:8766 VITE_SUPPORTS_NATIVE_DIALOGS=true VITE_SUPPORTS_SHELL_BRIDGE=true VITE_ENABLE_MOCK_SHELL_BRIDGE=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:desktop-mock": "VITE_RUNTIME_MODE=desktop-shell VITE_SHELL_NAME='Photo Calibrator Desktop' VITE_API_BASE_URL=http://127.0.0.1:8766 VITE_SUPPORTS_NATIVE_DIALOGS=true VITE_SUPPORTS_SHELL_BRIDGE=true VITE_ENABLE_MOCK_SHELL_BRIDGE=true vite preview",
    "typecheck": "tsc --noEmit",
    "electron": "electron electron/main.mjs",
    "electron:dev": "PHOTO_CALIBRATOR_RENDERER_MODE=dev PHOTO_CALIBRATOR_RENDERER_URL=http://127.0.0.1:5173 PHOTO_CALIBRATOR_API_BASE_URL=http://127.0.0.1:8766 electron electron/main.mjs",
    "electron:prod": "electron electron/main.mjs",
    "package:backend:mac": "PYINSTALLER_CONFIG_DIR=../build/pyinstaller-config ../.venv/bin/pyinstaller --clean --noconfirm --distpath ../build/backend --workpath ../build/pyinstaller ../packaging/photo-calibrator-backend.spec",
    "package:dmg:arm64": "npm run build && npm run package:backend:mac && electron-builder --mac dmg --arm64 --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "main": "electron/main.mjs",
  "build": {
    "appId": "com.yangxuran.photocalibrator",
    "productName": "Photo Calibrator",
    "asar": true,
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build/backend/photo-calibrator-backend",
        "to": "backend"
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "../packaging/entitlements.mac.plist",
      "entitlementsInherit": "../packaging/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "sign": false
    }
  }
}
